# ================================
# UzumBot Environment Variables
# Copy to .env and fill in values
# ================================

# ── PostgreSQL ───────────────────
POSTGRES_USER=uzumbot
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32CHARS
POSTGRES_DB=uzumbot

# ── Redis ────────────────────────
REDIS_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_32CHARS

# ── MinIO / File Storage ─────────
MINIO_ACCESS_KEY=CHANGE_THIS_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_THIS_SECRET_KEY_MIN_8CHARS
MINIO_BUCKET=uzumbot-files
# Public URL for serving files (set after Caddy is configured)
MINIO_PUBLIC_URL=https://files.yourdomain.com

# ── JWT Secrets ──────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_THIS_JWT_SECRET_MINIMUM_64_CHARS_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_MINIMUM_64_CHARS_LONG_STRING
ADMIN_JWT_SECRET=CHANGE_THIS_ADMIN_JWT_SECRET_64_CHARS_LONG_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30
ADMIN_JWT_EXPIRE_HOURS=8

# ── Admin Security ───────────────
# Number of failed login attempts before account lockout
ADMIN_LOGIN_MAX_ATTEMPTS=5
# Lockout duration in seconds (900 = 15 minutes)
ADMIN_LOGIN_LOCKOUT_SECONDS=900
# Require all admins to set up TOTP before they can access the panel
ADMIN_TOTP_REQUIRED=true

# ── Telegram Bot ─────────────────
BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
BOT_WEBHOOK_SECRET=CHANGE_THIS_RANDOM_HEX_64_CHARS
BOT_WEBHOOK_URL=https://api.yourdomain.com/api/v1/webhook/telegram
BOT_USERNAME=your_bot_username

# ── Bot ↔ Backend HMAC Signing ───
# Shared secret for signing bot-internal API requests (prevents replay attacks).
# Must be identical in both backend and bot services.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
BOT_API_HMAC_SECRET=CHANGE_THIS_HMAC_SECRET_64_CHARS_LONG

# ── App URLs ─────────────────────
API_BASE_URL=https://api.yourdomain.com
ADMIN_URL=https://admin.yourdomain.com
WEBAPP_URL=https://app.yourdomain.com
# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://admin.yourdomain.com,https://app.yourdomain.com

# ── Rate Limiting ────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ── File Upload ──────────────────
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ── Submissions ──────────────────
MAX_SUBMISSIONS_PER_DAY=3
MAX_IMAGES_PER_SUBMISSION=5

# ── Spin Settings ────────────────
SPIN_COOLDOWN_HOURS=24
# Bonus spins awarded to a referrer for each successful referral
REFERRAL_BONUS_SPINS=1

# ── Gamification ─────────────────
# XP awarded when a submission is approved
# GAMIFICATION_XP_SUBMISSION_APPROVED=50  (hardcoded default in gamification.py)
# XP bonus per active daily streak day
# GAMIFICATION_XP_STREAK_BONUS=10         (hardcoded default in gamification.py)

# ── Anti-Fraud ───────────────────
# Score thresholds for auto-ban and manual review queue
# FRAUD_AUTO_BAN_SCORE=80      (hardcoded default in fraud.py)
# FRAUD_REVIEW_QUEUE_SCORE=50  (hardcoded default in fraud.py)
# Max submissions per day / per week per user (enforced in fraud service)
# MAX_SUBMISSIONS_PER_DAY and MAX_SUBMISSIONS_PER_WEEK controlled by settings above

# ── Public Domain & Storage ──────────────────────────────────────────────
# The public hostname used by Caddy (no protocol)
PUBLIC_DOMAIN=uzum.n8nautomate.me
# Public base URL for rewriting presigned MinIO URLs so browsers can load images
# Set to https://yourdomain.com/minio when using the Caddy /minio/* reverse proxy
MINIO_PUBLIC_BASE_URL=https://uzum.n8nautomate.me/minio
MINIO_SECURE=false

# ── Support & Bot identity ────────────────────────────────────────────────
# Telegram username of the support account shown in /help (no @)
SUPPORT_USERNAME=your_support_username

# ── Admin Notifications ───────────────────────────────────────────────────
# Telegram chat/group ID for daily summaries and export-ready notifications
# Leave empty to disable (logs to worker stdout instead)
ADMIN_CHAT_ID=

# ── Monitoring ───────────────────
GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD

# ── Environment ──────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

