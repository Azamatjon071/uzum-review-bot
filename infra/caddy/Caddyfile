{$PUBLIC_DOMAIN:uzum.n8nautomate.me} {
    # ── MinIO file proxy (presigned URLs rewritten to /minio/*) ─────────────
    handle /minio/* {
        uri strip_prefix /minio
        reverse_proxy minio:9000 {
            header_up Host minio:9000
        }
    }

    # ── Bot Webhook → bot ────────────────────────────────────────────────────
    handle /api/v1/webhook/telegram {
        reverse_proxy bot:8080
    }

    # ── API → backend ────────────────────────────────────────────────────────
    handle /api/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up Host {host}
        }
    }

    handle /metrics {
        reverse_proxy backend:8000
    }

    # ── Telegram Mini App → webapp ───────────────────────────────────────────
    handle /app* {
        reverse_proxy webapp:80
    }

    # ── Admin Panel → admin (everything else) ────────────────────────────────
    handle {
        reverse_proxy admin:80
    }

    # ── Security headers ─────────────────────────────────────────────────────
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    encode gzip zstd

    log {
        output stdout
        format console
    }
}

edu.n8nautomate.me {
    # ── MinIO file proxy (rewrites /files/ to /edums-attachments/) ──────────
    handle_path /files/* {
        rewrite * /edums-attachments{path}
        reverse_proxy edums-minio:9000
    }

    # ── API → backend (8091) ─────────────────────────────────────────────────
    handle /api/* {
        reverse_proxy edums-backend:8091
    }
    handle /swagger-ui* {
        reverse_proxy edums-backend:8091
    }
    handle /v3/api-docs* {
        reverse_proxy edums-backend:8091
    }

    # ── Telegram Webapp (80) ─────────────────────────────────────────────────
    handle_path /webapp/* {
        reverse_proxy edums-telegram-webapp:80
    }

    # ── Frontend (Next.js) ───────────────────────────────────────────────────
    handle {
        reverse_proxy edums-frontend:3000
    }

    encode gzip zstd
}
